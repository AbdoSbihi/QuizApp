{
  "compilerOptions": {
    "target": "es2018",
    "lib": [ "es2018", "dom" ],
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "noImplicitAny": false,
    "noImplicitThis": false,
    "strictNullChecks": false,
    "skipLibCheck": true
  },
  "include": [ "src/**/*.ts", "wwwroot/Scripts/**/*.ts" ]
}